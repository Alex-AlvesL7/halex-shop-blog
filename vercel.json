{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/auth/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/og/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/produto/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/oferta/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/campanha/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/afiliado/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/blog",
      "dest": "server.ts"
    },
    {
      "src": "/blog/(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/loja",
      "dest": "server.ts"
    },
    {
      "src": "/dicas-ai",
      "dest": "server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
